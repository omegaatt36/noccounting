package components

import "fmt"

templ Result(success bool, name string, price uint64, currency string, categoryEmoji string, twdAmount string, errorMsg string) {
	<div
		id="toast-trigger"
		if success {
			data-success="true"
		} else {
			data-success="false"
		}
		data-name={ name }
		data-price={ fmt.Sprintf("%d", price) }
		data-currency={ currency }
		data-category-emoji={ categoryEmoji }
		data-twd-amount={ twdAmount }
		data-error={ errorMsg }
		style="display:none;"
	></div>
}
