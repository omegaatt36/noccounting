# ── Required ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
NOTION_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# Comma-separated list: telegram_id:notion_id:nickname
USER_MAPPING=123456789:abc123:Alice,987654321:def456:Bob

# ── Webapp ───────────────────────────────────────────────────────────────────
PORT=8080
# Set to "true" to skip Telegram initData validation (local development only)
DEV_MODE=false

# ── Bot ──────────────────────────────────────────────────────────────────────
# Mini App URL attached to the bot menu button
WEBAPP_URL=https://your-webapp-url.com

# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# ── Receipt scanning (optional) ──────────────────────────────────────────────
# OpenAI-compatible vision endpoint; leave blank to disable
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o
